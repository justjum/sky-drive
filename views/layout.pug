doctype html
html
  head
    title= title
    link(rel="stylesheet", href="/stylesheets/bootstrap.min.css")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous") 
    link(rel='stylesheet', href='/stylesheets/style.css')
  body
    div.navbar-expand-lg.d-flex
      div.container-fluid
        div 
          h1= title
        div
          if user 
            a(href="/log-out") Log Out 
          else
            form.log-in.d-flex.align-items-center.justify-content-center.gap-2(action="/log-in" method="post")
              div.mb-3 
                label.form-label(for="username")
                input.form-control(type="text" name="username" placeholder="Username")
              div.mb-3
                label.form-label(for="password")
                input.form-control(type="password" name="password" placeholder="Password")
              div.mb-3
                button.btn.btn-primary.align-self-end(type="submit") Login
    
    block content
